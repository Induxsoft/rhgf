#include "dkli.dkh"
#!
module ""
{
    switch @@(@http_context,"$request/get/_view")
    {
        case "buscar-puesto"
        {
            point @list to org.buscarPuesto
            break
        }
        case "buscar-empleado"
        {
            point @list to org.buscarEmpleado
            break
        }
        case "obtener-contratos"
        {
            point @list to org.obtenerContratos
            point @read to org.obtenerContratos
            break
        }
        case "unidad"
        {
            point @read to org.read
            point @blank to org.blank

            point @create to org.save
            point @update to org.save
            point @delete to org.delete

            @form_view = "form.unidad.dk"
            break
        }
        case "puesto"
        {
            point @read to org.read
            point @blank to org.blank

            point @create to org.save
            point @update to org.save
            point @delete to org.delete
            
            @form_view = "form.puesto.dk"
            break
        }
        case ""
        {
            point @list to org.list
            point @read to org.read
            point @blank to org.blank

            point @create to org.save
            point @update to org.save
            point @delete to org.delete

            @form_view = "form.contrato.dk"
            break
        }
    }
}