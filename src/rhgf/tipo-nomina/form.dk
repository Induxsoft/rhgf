                            }
                            input(type="hidden" name="var_empleado" value="#<@('$./var_empleado')>")
                        }
                    }
                }
            }
            script
            {
                $'
                tn.semanas="#<optionDias(@("$./final1"))>";
                tn.vars_field_name="#<@vars_field_name>";
                '
            }
        }
    }
}